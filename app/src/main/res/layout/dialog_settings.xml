<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 点击类型 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/click_type"
        android:textSize="16sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/rg_click_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <RadioButton
            android:id="@+id/rb_click_type_single"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/click_type_single" />

        <RadioButton
            android:id="@+id/rb_click_type_long_press"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/click_type_long_press" />
    </RadioGroup>

    <!-- 单次点击：间隔时间 -->
    <TextView
        android:id="@+id/tv_interval_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/click_interval_label"
        android:textSize="16sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_interval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="100"
        android:inputType="number"
        android:text="100" />

    <!-- 长按：推动距离 -->
    <TextView
        android:id="@+id/tv_swipe_distance_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/swipe_distance_label"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <EditText
        android:id="@+id/et_swipe_distance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="0"
        android:inputType="number"
        android:text="0"
        android:visibility="gone" />

    <!-- 长按：滑动方向 -->
    <TextView
        android:id="@+id/tv_swipe_direction_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/swipe_direction_label"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <RadioGroup
        android:id="@+id/rg_swipe_direction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <RadioButton
            android:id="@+id/rb_dir_up"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/swipe_direction_up" />

        <RadioButton
            android:id="@+id/rb_dir_down"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/swipe_direction_down" />

        <RadioButton
            android:id="@+id/rb_dir_left"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/swipe_direction_left" />

        <RadioButton
            android:id="@+id/rb_dir_right"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/swipe_direction_right" />

    </RadioGroup>

</LinearLayout>

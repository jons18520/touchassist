<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/target_outer_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/target_outer_stroke" />
            <size
                android:width="64dp"
                android:height="64dp" />
        </shape>
    </item>

    <item android:left="5dp" android:top="5dp" android:right="5dp" android:bottom="5dp">
        <shape android:shape="oval">
            <solid android:color="@color/target_middle_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/target_middle_stroke" />
        </shape>
    </item>
</layer-list>
